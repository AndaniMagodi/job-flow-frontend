{
    "manifest_version": 3,
    "name": "JobFlow",
    "version": "1.0.0",
    "description": "Log job applications in one click",
    "permissions": [
      "activeTab",
      "scripting",
      "storage"
    ],
   "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://www.linkedin.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://www.indeed.com/*",
    "https://*.workday.com/*",
    "https://www.pnet.co.za/*",
    "https://www.executiveplacements.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
      }
    },
    "content_scripts": [
        {
            "matches": [
              "https://www.linkedin.com/jobs/*",
              "https://*.greenhouse.io/jobs/*",
              "https://*.lever.co/*",
              "https://www.indeed.com/viewjob*",
              "https://*.workday.com/*",
              "https://www.pnet.co.za/*",
              "https://www.executiveplacements.com/*"
            ],
            "js": ["content.js"]
          }
    ]
  }